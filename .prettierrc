{
  "tabWidth": 2,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSameLine": true,
  "jsxSingleQuote": false,
  "plugins": [
    "prettier-plugin-astro",
    "prettier-plugin-multiline-arrays",
    "prettier-plugin-tailwindcss"
  ],
  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    }
  ]
}
