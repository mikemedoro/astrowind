---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';

const allArticles = (await getCollection(
  'articles'
)) as CollectionEntry<'articles'>[];

const latestArticles = allArticles
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<Layout
  title="Home"
  description="A modern Astro starter with React, Tailwind, and Prettier">
  <section class="container-fluid fl-py-14/28 border-b border-slate-100">
    <div class="max-w-2xl">
      <h1>Welcome to AstroWind</h1>
      <p class="fl-mt-4/6 max-w-prose text-slate-600">
        A modern Astro starter featuring React, Tailwind CSS v4, and Astro
        content collections — a fast, minimal foundation for building great
        websites.
      </p>
    </div>
  </section>

  <section class="container-fluid fl-py-10/20">
    <p class="eyebrow">Latest Articles</p>

    <div>
      <ul role="list">
        {
          latestArticles.map((article) => (
            <li class="article-card">
              <article>
                <p class="article-meta fl-mb-2/4">
                  {article.data.publishDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </p>
                <h2 class="type-h5 m-0">
                  <a
                    href={`/articles/${article.id}/`}
                    class="text-slate-900 no-underline transition-colors hover:text-slate-500">
                    {article.data.title}
                  </a>
                </h2>
                <p class="fl-mt-2/4 text-slate-600">
                  {article.data.description}
                </p>
              </article>
            </li>
          ))
        }
      </ul>
    </div>

    <p class="fl-mt-6/10">
      <a href="/articles" class="link-arrow">All articles &rarr;</a>
    </p>
  </section>
</Layout>
