---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';

export async function getStaticPaths() {
  const allArticles = (await getCollection(
    'articles'
  )) as CollectionEntry<'articles'>[];
  const articles = allArticles.filter((article) => !article.data.draft);

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

type Props = {
  article: CollectionEntry<'articles'>;
};

const { article } = Astro.props as Props;
const { Content } = await render(article);
const publishedDate = article.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={article.data.title} description={article.data.description}>
  <article class="container-fluid fl-py-10/20">
    <header class="fl-mb-8/14 fl-pb-8/14 max-w-3xl border-b border-slate-100">
      <p class="article-meta fl-mb-2/4">{publishedDate}</p>
      <h1>{article.data.title}</h1>
      <p class="fl-mt-4/6 fl-text-lg/xl leading-relaxed text-slate-600">
        {article.data.description}
      </p>
    </header>

    <div class="prose-content stack">
      <Content />
    </div>

    <p class="fl-mt-10/16 fl-pt-6/10 border-t border-slate-100">
      <a href="/articles" class="link-arrow">&larr; Back to articles</a>
    </p>
  </article>
</Layout>
