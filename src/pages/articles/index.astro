---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';

const allArticles = (await getCollection(
  'articles'
)) as CollectionEntry<'articles'>[];

const articles = allArticles
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Layout title="Articles" description="Latest articles and notes.">
  <section class="container-fluid fl-py-10/20">
    <div class="fl-mb-8/14 fl-pb-8/14 border-b border-slate-100">
      <h1>Articles</h1>
      <p class="fl-mt-4/6 text-slate-600">
        Thoughts on Astro, frontend architecture, and performance.
      </p>
    </div>

    <ul role="list">
      {
        articles.map((article) => (
          <li class="article-card">
            <article>
              <p class="article-meta fl-mb-2/4">
                {article.data.publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h2 class="type-h5 m-0">
                <a
                  href={`/articles/${article.id}/`}
                  class="text-slate-900 no-underline transition-colors hover:text-slate-500">
                  {article.data.title}
                </a>
              </h2>
              <p class="fl-mt-2/4 text-slate-600">{article.data.description}</p>
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
